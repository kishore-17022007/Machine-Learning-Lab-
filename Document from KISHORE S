        "# Install (if needed)\n",
        "# pip install pgmpy pandas\n",
        "\n",
        "import pandas as pd\n",
        "from pgmpy.models import DiscreteBayesianNetwork\n",
        "from pgmpy.estimators import BayesianEstimator\n",
        "from pgmpy.inference import VariableElimination\n",
        "\n",
        "# --------- LOAD DATA ---------\n",
        "data = pd.read_csv(\"heart_cleveland_upload.csv\")\n",
        "\n",
        "print(\"Data Loaded:\\n\", data.head())\n",
        "\n",
        "# --------- SELECT FEATURES ---------\n",
        "data = data[['age', 'chol', 'trestbps', 'cp', 'thalach', 'condition']]\n",
        "\n",
        "# Rename columns (easy names)\n",
        "data.columns = ['age', 'chol', 'trestbps', 'cp', 'thalach', 'condition']\n",
        "\n",
        "# --------- DISCRETIZE ---------\n",
        "# Use qcut for better distribution\n",
        "data['age'] = pd.qcut(data['age'], q=3, labels=[0,1,2])\n",
        "data['chol'] = pd.qcut(data['chol'], q=3, labels=[0,1,2])\n",
        "data['trestbps'] = pd.qcut(data['trestbps'], q=3, labels=[0,1,2])\n",
        "data['thalach'] = pd.qcut(data['thalach'], q=3, labels=[0,1,2])\n",
        "\n",
        "# ChestPain is already categorical в†’ no change\n",
        "\n",
        "# --------- DEFINE NETWORK ---------\n",
        "model = DiscreteBayesianNetwork([\n",
        "    ('age', 'condition'),\n",
        "    ('chol', 'condition'),\n",
        "    ('trestbps', 'condition'),\n",
        "    ('cp', 'condition'),\n",
        "    ('thalach', 'condition')\n",
        "])\n",
        "\n",
        "# --------- TRAIN MODEL (WITH SMOOTHING) ---------\n",
        "model.fit(\n",
        "    data,\n",
        "    estimator=BayesianEstimator,\n",
        "    prior_type=\"BDeu\",        # smoothing method\n",
        "    equivalent_sample_size=10 # controls smoothing strength\n",
        ")\n",
        "\n",
        "# --------- INFERENCE ---------\n",
        "infer = VariableElimination(model)\n",
        "\n",
        "# --------- TEST PATIENT ---------\n",
        "result = infer.query(\n",
        "    variables=['condition'],\n",
        "    evidence={\n",
        "        'age':2,        # High age\n",
        "        'chol':2,       # High cholesterol\n",
        "        'trestbps':2,         # High BP\n",
        "        'cp':3,  # Chest pain type\n",
        "        'thalach':0       # Low heart rate\n",
        "    }\n",
        ")\n",
        "\n",
        "# --------- OUTPUT ---------\n",
        "print(\"\\nPrediction:\")\n",
        "print(result)"
